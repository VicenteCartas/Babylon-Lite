{
    "name": "babylon-lite-workspace",
    "private": true,
    "license": "Apache-2.0",
    "packageManager": "pnpm@11.9.0",
    "engines": {
        "node": "^20.19.0 || ^22.13.0 || >=24"
    },
    "scripts": {
        "dev": "pnpm --filter @babylon-lite/parity-harness dev",
        "dev:playground": "pnpm --filter @babylon-lite/playground dev",
        "dev:playground:watch": "pnpm --filter @babylon-lite/playground dev:watch",
        "build:playground": "pnpm --filter @babylon-lite/playground build",
        "dev:lab": "pnpm build:bundle-scenes && tsx scripts/build-bundle-demos.ts && pnpm --filter @babylon-lite/lab dev",
        "build": "pnpm --filter babylon-lite build",
        "build:lib": "pnpm --filter babylon-lite build:lib",
        "build:gl": "pnpm --filter babylon-lite-gl build",
        "build:lab-site": "tsx scripts/build-lab-site.ts",
        "build:pages-site": "tsx scripts/build-pages-site.ts",
        "build:bundle-scenes": "pnpm build:lib && tsx scripts/build-bundle-scenes.ts",
        "build:bundle-scenes:gl": "tsx scripts/build-bundle-scenes-gl.ts",
        "build:bundle-demos": "tsx scripts/build-bundle-demos.ts",
        "build:bundle-demo": "tsx scripts/build-bundle-demo.ts",
        "build:bundle-master-info": "tsx scripts/build-master-bundle-info.ts",
        "fetch:freedoom": "tsx scripts/fetch-freedoom.ts",
        "fetch:librequake": "tsx scripts/fetch-librequake.ts",
        "fetch:voxelpack": "tsx scripts/fetch-voxelpack.ts",
        "fetch:freeciv": "tsx scripts/fetch-freeciv.ts",
        "fetch:platformer": "tsx scripts/fetch-platformer.ts",
        "fetch:littlest-tokyo": "tsx scripts/fetch-littlest-tokyo.ts",
        "test": "pnpm build:bundle-scenes && pnpm test:parity",
        "test:watch": "vitest --project unit",
        "test:unit": "vitest run --project unit",
        "test:unit:gl": "vitest run --project gl-unit",
        "test:build:gl": "vitest run --project gl-build",
        "test:build": "vitest run --project build",
        "test:no-webgpu": "vitest run --project no-webgpu",
        "test:audio-offline": "vitest run --project audio-offline",
        "test:bundle-size": "npx playwright test tests/lite/parity/bundle-size.spec.ts",
        "test:perf": "npx playwright test --config playwright.perf.config.ts",
        "test:parity": "npx playwright test tests/lite/parity",
        "test:parity:gl": "npx playwright test tests/gl/parity",
        "test:perf:gl": "npx playwright test --config playwright.perf.gl.config.ts tests/gl/perf/gl-perf-raf.spec.ts",
        "test:all": "npx playwright test && npx playwright test --config playwright.perf.config.ts",
        "test:perf-regression": "npx playwright test --config playwright.perf.config.ts tests/lite/perf/perf-regression.spec.ts",
        "test:perf-regression:gl": "npx playwright test --config playwright.perf.gl.config.ts tests/gl/perf/gl-perf-regression.spec.ts",
        "test:parity-cloud": "playwright test --config config/playwright.parity-cloud.config.ts",
        "test:perf-cloud": "tsx scripts/run-browserstack.ts playwright test --config config/playwright.perf-cloud.config.ts tests/lite/perf/perf-regression.spec.ts",
        "validate:release-markers": "tsx scripts/validate-pr-release-markers.ts",
        "gen:changelog": "tsx scripts/generate-changelog.ts",
        "validate:bundle-manifest": "tsx scripts/validate-bundle-manifest.ts",
        "report:api-changes": "tsx scripts/report-api-changes.ts",
        "gen:feature-doc": "tsx scripts/gen-feature-comparison.ts",
        "gen:feature-doc:check": "tsx scripts/gen-feature-comparison.ts --check",
        "build:perf-baseline": "tsx scripts/build-perf-baseline.ts",
        "lint": "eslint . && tsc -p packages/babylon-lite/tsconfig.json --noEmit && tsc -p packages/babylon-lite-gl/tsconfig.json --noEmit && tsc -p lab/tsconfig.typecheck.json --noEmit && tsc -p playground/tsconfig.json --noEmit && tsc -p tests/lite/tsconfig.json --noEmit && tsc -p tests/gl/tsconfig.json --noEmit",
        "lint:fix": "eslint . --fix",
        "typecheck:lab": "tsc -p lab/tsconfig.typecheck.json --noEmit",
        "typecheck:tests": "tsc -p tests/lite/tsconfig.json --noEmit",
        "format": "prettier --write \"packages/**/src/**/*.ts\" \"tests/lite/**/*.ts\" \"config/**/*.ts\" \"*.config.ts\" \"**/*.md\"",
        "format:check": "prettier --check \"packages/**/src/**/*.ts\" \"tests/lite/**/*.ts\" \"config/**/*.ts\" \"*.config.ts\" \"**/*.md\"",
        "analyze-bundle": "tsx scripts/analyze-bundle.ts",
        "coverage:scene": "tsx scripts/coverage-scene.ts",
        "docs": "typedoc",
        "docs:check": "typedoc --emit none --treatValidationWarningsAsErrors"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@microsoft/api-extractor": "^7.58.9",
        "@playwright/test": "^1.61.1",
        "@types/node": "^26.1.0",
        "@types/pngjs": "^6.0.5",
        "@webgpu/types": "^0.1.52",
        "browserstack-node-sdk": "^1.61.0",
        "browserstack-local": "^1.5.13",
        "dotenv": "^17.4.2",
        "esbuild": "^0.28.1",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-tsdoc": "^0.5.2",
        "globals": "^17.7.0",
        "miniray": "^0.3.1",
        "node-web-audio-api": "^2.0.0",
        "pngjs": "^7.0.0",
        "rollup-plugin-visualizer": "^7.0.1",
        "terser": "^5.48.0",
        "tsx": "^4.22.5",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vite": "^6.4.3",
        "vitest": "^4.1.9",
        "webpack": "^5.108.3"
    },
    "dependencies": {
        "prettier": "^3.9.4"
    }
}
