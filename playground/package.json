{
    "name": "@babylon-lite/playground",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build:engine": "vite build --config vite.engine.config.ts",
        "build:engine:watch": "vite build --config vite.engine.config.ts --watch",
        "build:types": "tsx scripts/build-engine-types.ts",
        "predev": "pnpm build:engine && pnpm build:types",
        "dev": "vite",
        "dev:watch": "pnpm build:types && tsx scripts/dev-watch.ts",
        "prebuild": "pnpm build:engine && pnpm build:types",
        "build": "vite build"
    },
    "dependencies": {
        "babylon-lite": "workspace:*",
        "fflate": "^0.8.2"
    },
    "devDependencies": {
        "@webgpu/types": "^0.1.52",
        "esbuild-wasm": "^0.25.0",
        "monaco-editor": "^0.54.0",
        "typescript": "^6.0.3",
        "vite": "^6.4.3"
    }
}
